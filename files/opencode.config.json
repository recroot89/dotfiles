{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "mcp": {
    "rails": {
      "type": "local",
      "command": ["rails-mcp-server", "--mode http"],
      "enabled": true,
      "environment": {
        "RAILS_ENV": "development"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "6000"
      }
    },
    "awx": {
      "type": "local",
      "command": ["python", "-m", "awx_mcp_server"],
      "environment": {
        "AWX_BASE_URL": "https://awx.example.com",
        "AWX_TOKEN": "${AWX_TOKEN}"
      }
    }
  }
}
